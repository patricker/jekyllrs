#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
PROFILE=${RUST_PROFILE:-debug}

# Try to embed Ruby's libdir as an rpath so `jekyllrs` can find libruby at runtime
RUBY_LIBDIR=""
if command -v ruby >/dev/null 2>&1; then
  RUBY_LIBDIR=$(ruby -rrbconfig -e 'print RbConfig::CONFIG["libdir"]' 2>/dev/null || true)
fi

if [[ -n "${RUBY_LIBDIR}" && -d "${RUBY_LIBDIR}" ]]; then
  # Use an rpath to Ruby's libdir; keep any existing RUSTFLAGS
  export RUSTFLAGS="${RUSTFLAGS:-} -C link-arg=-Wl,-rpath,${RUBY_LIBDIR}"
  echo "Embedding rpath to Ruby libdir: ${RUBY_LIBDIR}"
else
  echo "note: could not resolve Ruby libdir for rpath; falling back to default linker search path" >&2
fi

pushd "$REPO_ROOT/rust" > /dev/null
if [[ "$PROFILE" == "release" ]]; then
  cargo build --locked --release
  PROFILE_DIR=release
else
  cargo build --locked
  PROFILE_DIR=debug
fi
popd > /dev/null

LIB_NAME="libjekyll_core"
LIB_PATH="$REPO_ROOT/rust/target/$PROFILE_DIR/$LIB_NAME.so"

if [[ ! -f "$LIB_PATH" ]]; then
  echo "error: expected $LIB_PATH to exist" >&2
  exit 1
fi

echo "Rust build complete. Export this before running Ruby tests:"
echo "  export JEKYLL_RUST_LIB=$LIB_PATH"
