#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
PROFILE=${RUST_PROFILE:-debug}

# Try to embed Ruby's libdir as an rpath so `jekyllrs` can find libruby at runtime
RUBY_LIBDIR=""
if command -v ruby >/dev/null 2>&1; then
  RUBY_LIBDIR=$(ruby -rrbconfig -e 'print RbConfig::CONFIG["libdir"]' 2>/dev/null || true)
fi

if [[ -n "${RUBY_LIBDIR}" && -d "${RUBY_LIBDIR}" ]]; then
  # Use an rpath to Ruby's libdir; keep any existing RUSTFLAGS
  export RUSTFLAGS="${RUSTFLAGS:-} -C link-arg=-Wl,-rpath,${RUBY_LIBDIR}"
  echo "Embedding rpath to Ruby libdir: ${RUBY_LIBDIR}"
else
  echo "note: could not resolve Ruby libdir for rpath; falling back to default linker search path" >&2
fi

pushd "$REPO_ROOT/rust" > /dev/null

BUILD_ARGS=(build --offline)
if [[ "$PROFILE" == "release" ]]; then
  BUILD_ARGS+=(--release)
  cargo "${BUILD_ARGS[@]}"
  PROFILE_DIR=release
else
  cargo "${BUILD_ARGS[@]}"
  PROFILE_DIR=debug
fi
popd > /dev/null

HOST_TRIPLE=$(rustc -vV | sed -n 's/^host: //p')
DEFAULT_EXT=".so"
if [[ "$HOST_TRIPLE" == *"windows"* ]]; then
  DEFAULT_EXT=".dll"
elif [[ "$HOST_TRIPLE" == *"apple-darwin"* ]]; then
  DEFAULT_EXT=".dylib"
fi

EXTS=()
EXTS+=("$DEFAULT_EXT")
for extra in ".so" ".dylib" ".dll"; do
  add=true
  for existing in "${EXTS[@]}"; do
    if [[ "$existing" == "$extra" ]]; then
      add=false
      break
    fi
  done
  if $add; then
    EXTS+=("$extra")
  fi
done

LIB_PATH=""
for base in "libjekyll_core" "jekyll_core"; do
  for ext in "${EXTS[@]}"; do
    candidate="$REPO_ROOT/rust/target/$PROFILE_DIR/${base}${ext}"
    if [[ -f "$candidate" ]]; then
      LIB_PATH="$candidate"
      break 2
    fi
  done
done

if [[ -z "$LIB_PATH" ]]; then
  echo "error: could not find built jekyll_core cdylib under rust/target/$PROFILE_DIR" >&2
  exit 1
fi

echo "Rust build complete. Export this before running Ruby tests:"
echo "  export JEKYLL_RUST_LIB=$LIB_PATH"

DLEXT=""
if command -v ruby >/dev/null 2>&1; then
  DLEXT=$(ruby -rrbconfig -e 'print RbConfig::CONFIG["DLEXT"]' 2>/dev/null || true)
fi

if [[ -n "$DLEXT" ]]; then
  DEST_DIR="$REPO_ROOT/lib"
  mkdir -p "$DEST_DIR"
  DEST_PATH="$DEST_DIR/jekyll_core.$DLEXT"
  cp "$LIB_PATH" "$DEST_PATH"
  echo "Copied native library to $DEST_PATH for require 'jekyll_core'"
else
  echo "note: unable to determine Ruby DLEXT; skipping copy into lib/" >&2
fi
