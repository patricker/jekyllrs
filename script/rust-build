#!/usr/bin/env bash
# Build the Rust Jekyll core extension and install it where Ruby can find it.
#
# Usage:
#   script/rust-build          # release build (default)
#   script/rust-build debug    # debug build (faster compile, slower runtime)
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RUST_DIR="$PROJECT_ROOT/rust"
LIB_DST="$PROJECT_ROOT/lib/jekyll_core.so"

PROFILE="${1:-release}"

if [ "$PROFILE" = "debug" ]; then
    echo "Building Rust extension (debug)..."
    (cd "$RUST_DIR" && cargo build 2>&1)
    LIB_SRC="$RUST_DIR/target/debug/libjekyll_core.so"
else
    echo "Building Rust extension (release)..."
    (cd "$RUST_DIR" && cargo build --release 2>&1)
    LIB_SRC="$RUST_DIR/target/release/libjekyll_core.so"
fi

if [ ! -f "$LIB_SRC" ]; then
    echo "ERROR: Build failed — $LIB_SRC not found"
    exit 1
fi

cp "$LIB_SRC" "$LIB_DST"
SRC_SIZE=$(stat -c%s "$LIB_SRC" 2>/dev/null || stat -f%z "$LIB_SRC")
echo "Installed $(( SRC_SIZE / 1024 ))KB → lib/jekyll_core.so"
